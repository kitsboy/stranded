{
  "name": "stranded",
  "version": "2.3.6",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3003",
    "prebuild": "node scripts/generate-live-stats.js && node scripts/generate-sitemap.js",
    "build": "BUILD_STATIC=true next build",
    "postbuild": "node scripts/sync-docs.js",
    "start": "npx serve -p 3003 dist",
    "preview": "npm run build && npm run start",
    "lint": "next lint",
    "validate": "node scripts/validate-data.js",
    "test": "npm run validate && npm run test:helpers",
    "test:helpers": "node --import tsx scripts/test-helpers.mjs",
    "docs:sync": "node scripts/generate-live-stats.js && node scripts/sync-docs.js",
    "verify": "bash scripts/verify-pipeline.sh",
    "e2e": "playwright test",
    "deploy:check": "bash scripts/deploy-check.sh",
    "refresh-data": "node scripts/refresh-eccc-data.js",
    "nightly": "bash scripts/nightly-docs-sync.sh"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "js-cookie": "^3.0.5",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "maplibre-gl": "^5.22.0",
    "next": "14.2.5",
    "qrcode.react": "^4.2.0",
    "react": "^18",
    "react-dom": "^18",
    "react-leaflet": "^4.2.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/js-cookie": "^3.0.6",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
